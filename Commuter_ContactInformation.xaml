<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Commuter_ContactInformation"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid RowSpacing="0" ColumnSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                StrokeThickness="0"
                Padding="20,15"
                BackgroundColor="#2E7D32">
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="12" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Image Source="white_back.png" 
                       HeightRequest="22" 
                       WidthRequest="22"
                       VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackButtonClicked"/>
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="Edit Contact Information" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" BackgroundColor="#F8F9FA">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Frame BackgroundColor="White" 
                       CornerRadius="12" 
                       Padding="20" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="CONTACT NUMBER" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="#000000"/>
                        <Label Text="This number will be used for booking updates and ride notifications."
                               FontSize="12" 
                               TextColor="#666666"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,5,0,10"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Contact Number*" FontSize="12" TextColor="#666666"/>
                            <Grid ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="phil.png"
                                       WidthRequest="24"
                                       HeightRequest="24"
                                       VerticalOptions="Center"
                                       Grid.Column="0"
                                       Margin="5,0,5,0" />

                                <Border Grid.Column="1"
                                        Stroke="Transparent"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 0"
                                        BackgroundColor="Transparent"
                                        Padding="5,0"
                                        HeightRequest="50"
                                        Margin="-5,0,0,0">
                                    <Label Text="+63"
                                           FontSize="14"
                                           TextColor="#2E7D32"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"/>
                                </Border>

                                <Border Grid.Column="2"
                                        Stroke="#E0E0E0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="#F8F9FA"
                                        Padding="10,0"
                                        HeightRequest="50">
                                    <Entry x:Name="ContactNumberEntry"
                                           Placeholder="900 000 0000"
                                           FontSize="14"
                                           TextColor="#000000"
                                           BackgroundColor="Transparent"
                                           Keyboard="Telephone"
                                           VerticalOptions="Center"
                                           MaxLength="10"
                                           TextChanged="OnContactNumberTextChanged"/>
                                </Border>
                            </Grid>
                            <Label Text="Enter 10-digit mobile number (must start with 9)"
                                   FontSize="10" 
                                   TextColor="#888888"
                                   Margin="5,0,0,0"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" 
                       CornerRadius="12" 
                       Padding="20" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="E-MAIL ADDRESS" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="#000000"/>
                        <Label Text="Make sure to enter an active email you can access."
                               FontSize="12" 
                               TextColor="#666666"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,5,0,10"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="E-mail*" FontSize="12" TextColor="#666666"/>
                            <Border Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#F8F9FA"
                                    Padding="10,0"
                                    HeightRequest="50">
                                <Entry x:Name="EmailEntry"
                                       Placeholder="Add an e-mail address"
                                       FontSize="14"
                                       TextColor="#000000"
                                       Keyboard="Email"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="SubmitButton"
                        Text="Submit" 
                        BackgroundColor="#2E7D32" 
                        TextColor="White" 
                        FontSize="16" 
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="12"
                        Margin="0,10,0,30"
                        Clicked="OnSubmitClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="ProcessingOverlay" 
              IsVisible="False"
              HorizontalOptions="Fill"
              VerticalOptions="Fill"
              BackgroundColor="Transparent">
            <VerticalStackLayout Spacing="15" 
                                HorizontalOptions="Center" 
                                VerticalOptions="Center">
                <ActivityIndicator x:Name="ProcessingIndicator"
                                   Color="#2E7D32"
                                   IsRunning="False"
                                   HeightRequest="40"
                                   WidthRequest="40"/>
                <Label x:Name="ProcessingLabel"
                       Text="Checking..."
                       FontSize="14"
                       TextColor="#2E7D32"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>