<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ServiceCo.Commuter_AboutApp"
    BackgroundColor="#F4F6F8"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,10">
                <ImageButton 
                    Source="black_back.png"
                    HeightRequest="26"
                    WidthRequest="26"
                    BackgroundColor="Transparent"
                    Clicked="OnBackButtonClicked" />
                <Label 
                    Grid.Column="1"
                    Text="About App"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#222"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                <BoxView Grid.Column="2" WidthRequest="26" BackgroundColor="Transparent" />
            </Grid>

            <!-- APP INFO -->
            <Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Grid.Column="1"
                               Text="App Information"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E7D32"/>

                        <Label Text="GoTryke Tricycle Booking System"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="Black" />

                    <Label Text="A mobile-based tricycle booking system designed to provide commuters with an efficient, reliable, and accessible transportation service within the community."
                           FontSize="14"
                           TextColor="#555"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <!-- DEVELOPED BY -->
            <Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Grid.Column="1"
                               Text="Developed By"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="Black"
                               Margin="0,0,0,0" />

                        <Label Text="Developed by BSIS students of Bulacan Polytechnic College as part of their Capstone Project."
                           FontSize="14"
                           TextColor="#555"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <!-- LEGAL & POLICIES -->
            <Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Grid.Column="1"
                               Text="Legal &amp; Policies"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E7D32"/>
                    
                    <!-- Terms of Service -->
                    <Frame BackgroundColor="#F7F9FA" CornerRadius="12" Padding="15,10" HasShadow="False">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Terms of Service" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="#222"
                                   VerticalOptions="Center"/>
                            <ImageButton 
                                Grid.Column="1"
                                Source="greaterthan.png"
                                HeightRequest="18"
                                WidthRequest="18"
                                BackgroundColor="Transparent"
                                Clicked="OnTermsOfServiceClicked"/>
                        </Grid>
                    </Frame>

                    <!-- Privacy Policy -->
                    <Frame BackgroundColor="#F7F9FA" CornerRadius="12" Padding="15,10" HasShadow="False">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Privacy Policy" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="#222"
                                   VerticalOptions="Center"/>
                            <ImageButton 
                                Grid.Column="1"
                                Source="greaterthan.png"
                                HeightRequest="18"
                                WidthRequest="18"
                                BackgroundColor="Transparent"
                                Clicked="OnPrivacyPolicyClicked"/>
                        </Grid>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- VERSION INFO -->
            <Label Text="Version 1.0.0" 
                   FontSize="12"
                   TextColor="#888"
                   HorizontalOptions="Center"
                   Margin="0,10,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
