<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Commuter_Name"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Scrollable Content -->
        <ScrollView>
            <VerticalStackLayout
                Padding="25,70,25,25"
                Spacing="20"
                VerticalOptions="Start">

                <!-- Header Section -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Complete Your Profile"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#2E7D32"
                           HorizontalOptions="Start" />

                    <Label Text="Tell us your name to finish registration"
                           FontSize="14"
                           TextColor="#6B6B6B"
                           HorizontalOptions="Start" />
                </VerticalStackLayout>

                <!-- Form Section -->
                <VerticalStackLayout Spacing="20" Margin="0,10,0,0">

                    <!-- First Name Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="First Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2E7D32" />
                        <Border Stroke="#E0E0E0"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry x:Name="FirstNameEntry"
                                   Placeholder="Enter your first name"
                                   FontSize="14"
                                   PlaceholderColor="#A1A1A1"
                                   TextColor="Black"
                                   Margin="15,12"
                                   ClearButtonVisibility="WhileEditing"
                                   TextChanged="OnNameFieldChanged"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Middle Name Field (Optional) -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Middle Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#6B6B6B">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Middle Name " />
                                    <Span Text="(Optional)" 
                                          FontAttributes="Italic" 
                                          TextColor="#A1A1A1"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Border Stroke="#E0E0E0"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry x:Name="MiddleNameEntry"
                                   Placeholder="Enter your middle name"
                                   FontSize="14"
                                   PlaceholderColor="#A1A1A1"
                                   TextColor="Black"
                                   Margin="15,12"
                                   ClearButtonVisibility="WhileEditing"
                                   TextChanged="OnNameFieldChanged"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Last Name Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Last Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2E7D32" />
                        <Border Stroke="#E0E0E0"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry x:Name="LastNameEntry"
                                   Placeholder="Enter your last name"
                                   FontSize="14"
                                   PlaceholderColor="#A1A1A1"
                                   TextColor="Black"
                                   Margin="15,12"
                                   ClearButtonVisibility="WhileEditing"
                                   TextChanged="OnNameFieldChanged"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Sign Up Button -->
        <Button x:Name="SignUpButton"
                Text="Continue"
                FontAttributes="Bold"
                FontSize="16"
                TextColor="White"
                BackgroundColor="#DADADA"
                CornerRadius="12"
                HeightRequest="52"
                WidthRequest="140"
                Margin="0,0,20,30"
                VerticalOptions="End"
                HorizontalOptions="End"
                IsEnabled="False"
                Clicked="Sign_Up"/>
    </Grid>
</ContentPage>