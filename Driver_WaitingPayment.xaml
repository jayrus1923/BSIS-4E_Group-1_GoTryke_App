<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Driver_WaitingPayment"
             Title="Complete Payment"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="RootGrid">

        <!-- MAIN CONTENT -->
        <RefreshView x:Name="RefreshContainer"
                     RefreshColor="#2E7D32">
            <ScrollView>
                <VerticalStackLayout Spacing="20" Padding="16">

                    <!-- GoTryke Logo Header -->
                    <Frame BackgroundColor="Transparent" 
                           CornerRadius="0" 
                           Padding="10"
                           HasShadow="False">
                        <HorizontalStackLayout HorizontalOptions="Center">
                            <Image Source="gotryke_logo.png"
                                   HeightRequest="200"
                                   WidthRequest="200"
                                   Margin="0,-80,0,-77"
                                   Aspect="AspectFit"/>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Payment Status Banner -->
                    <Frame x:Name="PaymentStatusBanner"
                           BackgroundColor="#E8F5E9" 
                           CornerRadius="15" 
                           Padding="15"
                           HasShadow="True">
                        <HorizontalStackLayout Spacing="10">
                            <Frame x:Name="StatusIconFrame"
                                   BackgroundColor="#4CAF50"
                                   CornerRadius="10"
                                   Padding="10"
                                   WidthRequest="44"
                                   HeightRequest="44">
                                <Label x:Name="StatusIconLabel"
                                       Text="⏳"
                                       FontSize="19"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="White"/>
                            </Frame>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="StatusTitleLabel"
                                       Text="Waiting for Payment" 
                                       FontSize="14" 
                                       FontAttributes="Bold" 
                                       TextColor="#2E7D32"/>
                                <Label x:Name="StatusSubtitleLabel"
                                       Text="Passenger is completing payment" 
                                       FontSize="12" 
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Ride ID Display -->
                    <Frame BackgroundColor="White" 
                           CornerRadius="15" 
                           Padding="20" 
                           HasShadow="True">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📋 RIDE DETAILS" FontSize="14" FontAttributes="Bold" TextColor="#2E7D32"/>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="Ride ID:" FontSize="13" TextColor="#666666"/>
                                <Label x:Name="RideIdLabel" Grid.Column="1" Text="Loading..." FontSize="13" FontAttributes="Bold" TextColor="#333333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Passenger Info -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="🧑 PASSENGER" FontSize="14" FontAttributes="Bold" TextColor="#2E7D32"/>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                                <Frame Grid.Column="0"
                                       BackgroundColor="White"
                                       Padding="0"
                                       CornerRadius="35"
                                       HeightRequest="70"
                                       WidthRequest="70"
                                       HasShadow="True"
                                       BorderColor="#E0E0E0">
                                    <Image x:Name="PassengerImage"
                                           Source="profile_icon.png"
                                           Aspect="AspectFill"
                                           HeightRequest="70"
                                           WidthRequest="70">
                                        <Image.Clip>
                                            <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                                        </Image.Clip>
                                    </Image>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" 
                                                     Spacing="6"
                                                     VerticalOptions="Center">
                                    <Label x:Name="PassengerNameLabel" 
                                           Text="Passenger" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="Black"/>
                                    <HorizontalStackLayout Spacing="5">
                                        <Image Source="star_filled.png"
                                               HeightRequest="14"
                                               WidthRequest="14"/>
                                        <Label x:Name="PassengerRatingLabel" 
                                               Text="New" 
                                               FontSize="13" 
                                               TextColor="#666666"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Trip Details -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="📍 ROUTE" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Frame BackgroundColor="#E8F5E9"
                                       Padding="12"
                                       CornerRadius="12"
                                       HeightRequest="48"
                                       WidthRequest="48"
                                       VerticalOptions="Center"
                                       HasShadow="False">
                                    <Image Source="pickup.png"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" 
                                                     Spacing="3"
                                                     VerticalOptions="Center">
                                    <Label Text="FROM"
                                           FontSize="10"
                                           TextColor="#666666"
                                           FontAttributes="Bold"/>
                                    <Label x:Name="PickupLabel"
                                           Text="Loading..."
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="Black"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Grid Margin="23,2,0,2"
                                  HeightRequest="30"
                                  WidthRequest="20">
                                <VerticalStackLayout Spacing="3"
                                                     HorizontalOptions="Center">
                                    <BoxView HeightRequest="4"
                                             WidthRequest="4"
                                             BackgroundColor="#CCCCCC"
                                             CornerRadius="2"/>
                                    <BoxView HeightRequest="4"
                                             WidthRequest="4"
                                             BackgroundColor="#CCCCCC"
                                             CornerRadius="2"/>
                                    <BoxView HeightRequest="4"
                                             WidthRequest="4"
                                             BackgroundColor="#CCCCCC"
                                             CornerRadius="2"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*,Auto" 
                                  ColumnSpacing="12"
                                  Margin="0,0,0,0">

                                <Frame BackgroundColor="#FFEBEE"
                                       Padding="12"
                                       CornerRadius="12"
                                       HeightRequest="48"
                                       WidthRequest="48"
                                       VerticalOptions="Center"
                                       HasShadow="False">
                                    <Image Source="dropoff.png"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" 
                                                     Spacing="3"
                                                     VerticalOptions="Center">
                                    <Label Text="TO"
                                           FontSize="10"
                                           TextColor="#666666"
                                           FontAttributes="Bold"/>
                                    <Label x:Name="DropoffLabel"
                                           Text="Loading..."
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="Black"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Fare Summary -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="💰 FARE SUMMARY" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Padding="0,10">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="DISTANCE" FontSize="12" TextColor="#666666"/>
                                    <Label x:Name="DistanceLabel" 
                                           Text="0 km" 
                                           FontSize="14" 
                                           TextColor="Black" 
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="DURATION" FontSize="12" TextColor="#666666"/>
                                    <Label x:Name="DurationLabel" 
                                           Text="0 mins" 
                                           FontSize="14" 
                                           TextColor="Black" 
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,5"/>

                            <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                                <Label Text="TOTAL FARE" 
                                       FontSize="12" 
                                       TextColor="#666666" 
                                       HorizontalOptions="Center"/>
                                <Label x:Name="FareLabel" 
                                       Text="₱0" 
                                       FontSize="36" 
                                       FontAttributes="Bold" 
                                       TextColor="#2E7D32" 
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Payment Method -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="💳 PAYMENT METHOD" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                            <Frame x:Name="SelectedPaymentFrame"
                                   BackgroundColor="White"
                                   CornerRadius="15"
                                   Padding="15"
                                   HasShadow="True"
                                   BorderColor="#E0E0E0"
                                   HeightRequest="80">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Frame x:Name="SelectedPaymentIconFrame"
                                           BackgroundColor="#E8F5E9"
                                           CornerRadius="10" 
                                           Padding="12"
                                           HeightRequest="44"
                                           WidthRequest="44"
                                           VerticalOptions="Center">
                                        <Image x:Name="SelectedPaymentIcon"
                                               Source="cash.png"
                                               HeightRequest="20"
                                               WidthRequest="20"
                                               Aspect="AspectFit"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"/>
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" 
                                                         Spacing="2" 
                                                         Padding="15,0"
                                                         VerticalOptions="Center">
                                        <Label x:Name="SelectedPaymentLabel"
                                               Text="Select Payment"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#333333"/>
                                        <Label x:Name="SelectedPaymentDescription"
                                               Text="Waiting for passenger selection"
                                               FontSize="11"
                                               TextColor="#666666"/>
                                    </VerticalStackLayout>

                                    <Frame x:Name="PaymentStatusBadge"
                                           Grid.Column="2"
                                           BackgroundColor="#FFF3E0"
                                           CornerRadius="8"
                                           Padding="10,5"
                                           HeightRequest="30"
                                           VerticalOptions="Center">
                                        <Label Text="Waiting"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#FF9800"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"/>
                                    </Frame>
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Rating Received -->
                    <Frame x:Name="RatingReceivedFrame"
                           BackgroundColor="White" 
                           CornerRadius="15" 
                           Padding="20"
                           HasShadow="True"
                           IsVisible="False">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="⭐ RATING RECEIVED" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                            <Label x:Name="RatingMessageLabel"
                                   Text="Passenger rated your service" 
                                   FontSize="13" 
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>

                            <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label x:Name="ReceivedStar1" 
                                       Text="★" 
                                       FontSize="24" 
                                       TextColor="#E0E0E0"/>
                                <Label x:Name="ReceivedStar2" 
                                       Text="★" 
                                       FontSize="24" 
                                       TextColor="#E0E0E0"/>
                                <Label x:Name="ReceivedStar3" 
                                       Text="★" 
                                       FontSize="24" 
                                       TextColor="#E0E0E0"/>
                                <Label x:Name="ReceivedStar4" 
                                       Text="★" 
                                       FontSize="24" 
                                       TextColor="#E0E0E0"/>
                                <Label x:Name="ReceivedStar5" 
                                       Text="★" 
                                       FontSize="24" 
                                       TextColor="#E0E0E0"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Payment Ready Frame -->
                    <Frame x:Name="PaymentReadyFrame"
                           BackgroundColor="#E8F5E9"
                           CornerRadius="15"
                           Padding="20"
                           HasShadow="True"
                           IsVisible="False">
                        <VerticalStackLayout Spacing="15">
                            <HorizontalStackLayout Spacing="10">
                                <Frame BackgroundColor="#4CAF50"
                                       CornerRadius="10"
                                       Padding="12"
                                       WidthRequest="44"
                                       HeightRequest="44">
                                    <Label Text="💰"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           TextColor="White"/>
                                </Frame>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Payment Ready" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="#2E7D32"/>
                                    <Label Text="Passenger has sent payment" 
                                           FontSize="13" 
                                           TextColor="#666666"/>
                                    <Label x:Name="PaymentTimeLabel"
                                           Text=""
                                           FontSize="11"
                                           TextColor="#666666"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <Button x:Name="PaymentReceivedButton"
                                    Text="CONFIRM PAYMENT RECEIVED"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    CornerRadius="12"
                                    HeightRequest="50"
                                    Clicked="OnPaymentReceivedClicked"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Real-time Status -->
                    <Frame BackgroundColor="#F0F9F0" 
                           CornerRadius="12" 
                           Padding="15,10"
                           HasShadow="True">
                        <HorizontalStackLayout Spacing="10">
                            <ActivityIndicator x:Name="RealtimeStatusIndicator"
                                           IsRunning="True" 
                                           Color="#2E7D32"
                                           WidthRequest="16"
                                           HeightRequest="16"/>
                            <Label x:Name="RealtimeStatusLabel"
                               Text="Waiting for passenger payment..."
                               FontSize="12"
                               TextColor="#2E7D32"
                               VerticalOptions="Center"
                               HorizontalOptions="StartAndExpand"/>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Return Home Button -->
                    <Button x:Name="ReturnHomeButton"
                        Text="RETURN TO HOME"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="55"
                        Clicked="OnReturnHomeClicked"
                        IsVisible="False"/>

                    <!-- Back Button -->
                    <Button Text="BACK"
                        BackgroundColor="Transparent"
                        TextColor="#666666"
                        FontSize="14"
                        CornerRadius="12"
                        HeightRequest="45"
                        Clicked="OnBackTapped"/>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- LOADING OVERLAY - Nasa ibabaw ng lahat -->
        <Grid x:Name="LoadingOverlay"
              BackgroundColor="#80000000"
              IsVisible="False"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand"
              InputTransparent="True">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                <Frame BackgroundColor="White"
                       CornerRadius="20"
                       Padding="30"
                       WidthRequest="200"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True" Color="#2E7D32" HeightRequest="50" WidthRequest="50"/>
                        <Label Text="Processing..." 
                               TextColor="#2E7D32" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>