                        <Label 
                            Text="How can we help you today?"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#1E293B" />
                        <Label 
                            Text="Find answers to common questions or contact our support team"
                            FontSize="13"
                            TextColor="#64748B"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- FAQ Section -->
            <Grid RowDefinitions="Auto,*">
                <Label 
                    Text="Frequently Asked Questions"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="#1E293B"
                    Margin="0,0,0,10" />

                <Frame Grid.Row="1" BackgroundColor="Transparent" CornerRadius="20" Padding="0" HasShadow="False">
