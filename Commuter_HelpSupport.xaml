                                            <Label 
                                                Text="Select vehicle type"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="#1E293B" />
                                            <Label 
                                                Text="Choose from available options"
                                                FontSize="12"
                                                TextColor="#64748B"
                                                LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Grid ColumnDefinitions="28,*" ColumnSpacing="15">
                                        <Frame 
                                            BackgroundColor="#10B981"
                                            CornerRadius="20"
                                            Padding="0"
                                            WidthRequest="28"
                                            HeightRequest="28">
