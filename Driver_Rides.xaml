<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Driver_Rides"
             BackgroundColor="#F5F7FA"
             Shell.NavBarIsVisible="False"
             Title="My Rides">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid BackgroundColor="#2E7D32" 
              Padding="20,15" 
              Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <HorizontalStackLayout Grid.Column="0" 
                                   Spacing="15" 
                                   VerticalOptions="Center">
                <Image Source="tricycle.png"
                       WidthRequest="40"
                       HeightRequest="40"
                       VerticalOptions="Center"/>
                <Label Text="My Rides"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <ImageButton x:Name="HistoryButton"
                         Grid.Column="2"
                         Source="history.png"
                         WidthRequest="26"
                         HeightRequest="26"
                         HorizontalOptions="End"
                         VerticalOptions="Center"
                         BackgroundColor="Transparent"
                         Clicked="OnHistoryButtonClicked"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <!-- EMPTY STATE -->
            <VerticalStackLayout x:Name="EmptyStateLayout"
                                 Padding="40"
                                 Spacing="25"
                                 HorizontalOptions="Center"
                                 VerticalOptions="CenterAndExpand"
                                 IsVisible="False">

                <Image Source="rides_approved.png"
                       HeightRequest="125"
                       WidthRequest="125"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"/>

                <Label Text="No rides yet"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#333333"
                       HorizontalOptions="Center"/>

                <Label Text="Your rides will appear here after accepting bookings."
                       FontSize="14"
                       TextColor="#757575"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       MaxLines="2"
                       LineBreakMode="WordWrap"
                       WidthRequest="250"/>
            </VerticalStackLayout>

            <!-- RIDES LIST -->
            <RefreshView x:Name="RidesRefreshView"
                         IsVisible="False"
                         RefreshColor="#2E7D32"
                         Command="{Binding RefreshCommand}"
                         IsRefreshing="{Binding IsRefreshing}">

                <ScrollView>
                    <VerticalStackLayout x:Name="RidesListContainer"
                                         Padding="16"
                                         Spacing="12"/>
                </ScrollView>
            </RefreshView>

            <!-- LOADING INDICATOR -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               Color="#2E7D32"
                               HeightRequest="50"
                               WidthRequest="50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="False"/>

            <!-- STATUS VIEWS -->
            <ScrollView x:Name="StatusViewsScrollView"
                        IsVisible="False">
                <StackLayout Spacing="16" Padding="16">

                    <!-- WAITING FOR APPROVAL -->
                    <StackLayout x:Name="WaitingView" IsVisible="False">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#E8F5E9"
                                       HorizontalOptions="Center">
                                    <Image Source="waiting_approval.png"
                                           WidthRequest="60"
                                           HeightRequest="60"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Waiting for Approval"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           TextColor="#2E7D32" />
                                    <Label Text="Your application is being reviewed by admin."
                                           FontSize="14"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Rides will appear here once approved."
                                           FontSize="13"
                                           TextColor="#999999"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                                <ActivityIndicator IsRunning="True"
                                                   Color="#2E7D32"
                                                   HeightRequest="30"/>
                            </StackLayout>
                        </Frame>

                        <Frame BackgroundColor="White"
                               Padding="20"
                               CornerRadius="16"
                               Margin="0,10,0,0"
                               HasShadow="False"
                               BorderColor="#F0F0F0">
                            <StackLayout Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">
                                    <Border Grid.Column="0"
                                            Stroke="#2E7D32"
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="#E8F5E9"
                                            Padding="6,3"
                                            HorizontalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="⏳" 
                                                   FontSize="11"
                                                   TextColor="#2E7D32"
                                                   VerticalOptions="Center"/>
                                            <Label Text="Documents" 
                                                   FontSize="11"
                                                   TextColor="#2E7D32"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Label Grid.Column="1" 
                                           Text="──────" 
                                           TextColor="#E0E0E0"
                                           FontSize="14"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Margin="5,0"/>
                                    <Border Grid.Column="2"
                                            Stroke="#E0E0E0"
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="White"
                                            Padding="6,3"
                                            HorizontalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="🛵" 
                                                   FontSize="11"
                                                   TextColor="#9E9E9E"
                                                   VerticalOptions="Center"/>
                                            <Label Text="Tricycle" 
                                                   FontSize="11"
                                                   TextColor="#9E9E9E"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Frame Grid.Column="0"
                                           BackgroundColor="#2E7D32"
                                           CornerRadius="12"
                                           Padding="8,4"
                                           HorizontalOptions="Start">
                                        <Label Text="Step 1/2"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                    </Frame>
                                    <Label Grid.Column="1"
                                           Text="Waiting for Document Approval"
                                           FontSize="13"
                                           TextColor="#2E7D32"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <Border Stroke="#E0E0E0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        HeightRequest="6"
                                        BackgroundColor="White">
                                    <Border Stroke="#2E7D32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            BackgroundColor="#2E7D32"
                                            WidthRequest="150"
                                            HorizontalOptions="Start"/>
                                </Border>
                                <Label Text="⏳ Your documents are being reviewed by admin"
                                       FontSize="11"
                                       TextColor="#666666"
                                       HorizontalOptions="Center"
                                       Margin="0,5,0,0"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- DOCUMENTS REJECTED -->
                    <StackLayout x:Name="RejectedView" IsVisible="False">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FFEBEE"
                                       HorizontalOptions="Center">
                                    <Label Text="❌"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Application Rejected"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           TextColor="#D32F2F" />
                                    <Label x:Name="RejectionReasonLabel"
                                           Text="Your documents did not meet the requirements."
                                           FontSize="14"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                                <BoxView HeightRequest="1" BackgroundColor="#FFCDD2" Margin="0,10"/>
                                <StackLayout Spacing="15" HorizontalOptions="Center">
                                    <Label Text="Please re-upload the required document:"
                                           FontSize="14"
                                           TextColor="#D32F2F"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                    <Button x:Name="ReuploadButton"
                                            Text="Re-upload Document"
                                            BackgroundColor="#EF4444"
                                            TextColor="White"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            CornerRadius="25"
                                            HeightRequest="50"
                                            WidthRequest="250"
                                            Clicked="OnReuploadClicked"/>
                                    <Label Text="Your document will be reviewed again within 24 hours."
                                           FontSize="12"
                                           TextColor="#999"
                                           HorizontalOptions="Center"/>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- SUSPENDED -->
                    <StackLayout x:Name="SuspendedView" IsVisible="False" Spacing="16">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FEF3C7"
                                       HorizontalOptions="Center">
                                    <Label Text="⏸️"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Account Suspended"
                                           FontAttributes="Bold"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="#F59E0B" />
                                    <Label x:Name="SuspendedMessageLabel"
                                           Text="Your account has been suspended by admin."
                                           FontSize="16"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label x:Name="SuspendedUntilLabel"
                                           Text=""
                                           FontSize="14"
                                           TextColor="#F59E0B"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                    <Label Text="You cannot view rides while suspended."
                                           FontSize="14"
                                           TextColor="#999999"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                                <Button Text="Contact Support"
                                        BackgroundColor="#F59E0B"
                                        TextColor="White"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        CornerRadius="25"
                                        HeightRequest="50"
                                        WidthRequest="250"
                                        Clicked="OnContactSupportClicked"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- DEACTIVATED -->
                    <StackLayout x:Name="DeactivatedView" IsVisible="False" Spacing="16">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FEE2E2"
                                       HorizontalOptions="Center">
                                    <Label Text="🚫"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Account Deactivated"
                                           FontAttributes="Bold"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="#EF4444" />
                                    <Label x:Name="DeactivatedMessageLabel"
                                           Text="Your account has been deactivated by admin."
                                           FontSize="16"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="You can no longer use this account."
                                           FontSize="14"
                                           TextColor="#999999"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                                <Button Text="Contact Support"
                                        BackgroundColor="#EF4444"
                                        TextColor="White"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        CornerRadius="25"
                                        HeightRequest="50"
                                        WidthRequest="250"
                                        Clicked="OnContactSupportClicked"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- TRICYCLE REJECTED -->
                    <StackLayout x:Name="TricycleRejectedSection" IsVisible="False" Spacing="16">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FFEBEE"
                                       HorizontalOptions="Center">
                                    <Label Text="❌"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Tricycle Rejected"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           TextColor="#D32F2F" />
                                    <Label x:Name="TricycleRejectionReasonLabel"
                                           Text="Your tricycle details were rejected by admin."
                                           FontSize="14"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Please update your information and resubmit."
                                           FontSize="13"
                                           TextColor="#999999"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                                <Button x:Name="TricycleRejectedEditButton"
                                        Text="Edit Tricycle Details"
                                        BackgroundColor="#D32F2F"
                                        TextColor="White"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        CornerRadius="25"
                                        HeightRequest="50"
                                        WidthRequest="250"
                                        Clicked="OnEditTricycleClicked"/>
                            </StackLayout>
                        </Frame>
                        <Frame BackgroundColor="#FFEBEE"
                               Padding="15"
                               CornerRadius="12">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="ℹ️"
                                       FontSize="16"
                                       TextColor="#D32F2F"/>
                                <Label Text="Fix the issues and resubmit for approval."
                                       FontSize="13"
                                       TextColor="#D32F2F"
                                       HorizontalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- TRICYCLE PENDING -->
                    <StackLayout x:Name="TricyclePendingSection" IsVisible="False" Spacing="16">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FFF3E0"
                                       HorizontalOptions="Center">
                                    <Label Text="🛵"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Tricycle Pending Approval"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           TextColor="#F57C00" />
                                    <Label Text="Your tricycle details are being reviewed by admin."
                                           FontSize="14"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Complete your tricycle details to view rides."
                                           FontSize="13"
                                           TextColor="#999999"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                                <Button x:Name="GoToEditTricycleButton"
                                        Text="Go to Edit Tricycle"
                                        BackgroundColor="#F57C00"
                                        TextColor="White"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        CornerRadius="25"
                                        HeightRequest="50"
                                        WidthRequest="250"
                                        Clicked="OnEditTricycleClicked"/>
                            </StackLayout>
                        </Frame>

                        <Frame BackgroundColor="White"
                               Padding="20"
                               CornerRadius="16"
                               HasShadow="False"
                               BorderColor="#F0F0F0">
                            <StackLayout Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">
                                    <Border Grid.Column="0"
                                            Stroke="#2E7D32"
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="#E8F5E9"
                                            Padding="6,3"
                                            HorizontalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="✓" 
                                                   FontSize="12"
                                                   TextColor="#2E7D32"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                            <Label Text="Documents" 
                                                   FontSize="11"
                                                   TextColor="#2E7D32"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Label Grid.Column="1" 
                                           Text="──────" 
                                           TextColor="#2E7D32"
                                           FontSize="14"
                                           Opacity="0.8"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Margin="5,0"/>
                                    <Border Grid.Column="2"
                                            Stroke="#F57C00"
                                            StrokeThickness="3"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="#FFF3E0"
                                            Padding="6,3"
                                            HorizontalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="⏳" 
                                                   FontSize="11"
                                                   TextColor="#F57C00"
                                                   VerticalOptions="Center"/>
                                            <Label Text="Tricycle" 
                                                   FontSize="11"
                                                   TextColor="#F57C00"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Frame Grid.Column="0"
                                           BackgroundColor="#F57C00"
                                           CornerRadius="12"
                                           Padding="8,4"
                                           HorizontalOptions="Start">
                                        <Label Text="Step 2/2"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                    </Frame>
                                    <Label Grid.Column="1"
                                           Text="Waiting for Tricycle Approval"
                                           FontSize="13"
                                           TextColor="#F57C00"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <Border Stroke="#E0E0E0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        HeightRequest="6"
                                        BackgroundColor="White">
                                    <Border Stroke="#F57C00"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            BackgroundColor="#F57C00"
                                            WidthRequest="300"
                                            HorizontalOptions="Start"/>
                                </Border>
                                <Label Text="⏳ ✓ Documents approved • Waiting for tricycle review"
                                       FontSize="11"
                                       TextColor="#F57C00"
                                       HorizontalOptions="Center"
                                       Margin="0,5,0,0"
                                       LineBreakMode="WordWrap"/>
                            </StackLayout>
                        </Frame>

                        <Frame BackgroundColor="#FFF3E0"
                               Padding="15"
                               CornerRadius="12">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="ℹ️"
                                       FontSize="16"
                                       TextColor="#F57C00"
                                       Margin="0,5,0,0"/>
                                <Label Text="Your rides will appear once your tricycle is approved."
                                       FontSize="13"
                                       TextColor="#F57C00"
                                       HorizontalOptions="Center"
                                       WidthRequest="300"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </StackLayout>
                </StackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>