<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ServiceCo.Driver_Home"
    BackgroundColor="#F5F7FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- APPROVED MODAL -->
        <Frame x:Name="ApprovedModal"
               Grid.RowSpan="3"
               BackgroundColor="#2E7D32"
               CornerRadius="20"
               Padding="30"
               HasShadow="True"
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="300"
               ZIndex="1000">
            <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                <Frame BackgroundColor="White"
                       CornerRadius="50"
                       Padding="20"
                       WidthRequest="80"
                       HeightRequest="80">
                    <Label Text="✅" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
                <Label x:Name="ApprovedModalTitle"
                       Text="APPROVED!" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="White"
                       HorizontalOptions="Center"/>
                <Label x:Name="ApprovedModalMessage"
                       Text="Your account has been approved by admin!"
                       FontSize="14"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>
                <Button Text="GO TO DASHBOARD"
                        BackgroundColor="White"
                        TextColor="#2E7D32"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        WidthRequest="200"
                        Clicked="OnGoToDashboardClicked"/>
            </VerticalStackLayout>
        </Frame>

        <!-- HEADER -->
        <Grid BackgroundColor="#2E7D32" Padding="20,15" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <HorizontalStackLayout HorizontalOptions="Start"
                                   VerticalOptions="Center"
                                   Spacing="8">
                <Image Source="tricycle.png"
                       HeightRequest="40"
                       WidthRequest="40"
                       VerticalOptions="Center" />
                <Label VerticalOptions="Center"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Go" FontAttributes="Bold" />
                            <Span Text="Tryke" TextColor="#FFC107" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <Grid Grid.Column="1">
                <Button BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="40"
                        HeightRequest="40"
                        Clicked="OnNotificationButtonClicked">
                    <Button.ImageSource>
                        <FontImageSource Glyph="🔔"
                                       Color="White"
                                       Size="22" />
                    </Button.ImageSource>
                </Button>
                <Frame x:Name="NotificationBadge"
                       BackgroundColor="#EF4444"
                       CornerRadius="15"
                       Padding="8,4"
                       HorizontalOptions="End"
                       VerticalOptions="Start"
                       IsVisible="False"
                       Margin="15,-5,0,0">
                    <Label x:Name="NotificationBadgeText"
                           Text="0"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </Frame>
            </Grid>
        </Grid>

        <!-- CONNECTION ERROR BANNER -->
        <Grid Grid.RowSpan="3" 
              x:Name="ConnectionErrorGrid"
              IsVisible="False"
              BackgroundColor="Transparent"
              VerticalOptions="Start"
              HorizontalOptions="FillAndExpand"
              Margin="0,20,0,0"
              ZIndex="999"
              Padding="20,70,20,0">

            <Frame x:Name="ConnectionErrorBanner"
                   BackgroundColor="#FFEBEE"
                   BorderColor="#F44336"
                   CornerRadius="10"
                   Padding="15,10"
                   HasShadow="True">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Label x:Name="ConnectionErrorLabel"
                           Grid.Column="0"
                           Text="No internet connection. Some features may be limited."
                           TextColor="#D32F2F"
                           FontSize="13"
                           VerticalOptions="Center"
                           LineBreakMode="WordWrap"/>
                    <Button x:Name="RetryConnectionButton"
                            Grid.Column="1"
                            Text="Retry"
                            TextColor="White"
                            BackgroundColor="#D32F2F"
                            CornerRadius="5"
                            Padding="15,5"
                            FontSize="12"
                            FontAttributes="Bold"
                            Clicked="OnRetryConnectionClicked"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- MAIN CONTENT -->
        <RefreshView Grid.Row="1"
                     x:Name="RefreshView"
                     RefreshColor="#2E7D32"
                     Refreshing="OnRefreshing">
            <ScrollView Padding="16,16,16,20">
                <StackLayout Spacing="16">

                    <!-- WAITING VIEW -->
                    <StackLayout x:Name="WaitingView" IsVisible="False">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#E8F5E9"
                                       HorizontalOptions="Center">
                                    <Image Source="waiting_approval.png"
                                           WidthRequest="60"
                                           HeightRequest="60"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Waiting for Approval"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           TextColor="#2E7D32" />
                                    <Label Text="Your application is being reviewed by admin."
                                           FontSize="14"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="This usually takes 24-48 hours."
                                           FontSize="13"
                                           TextColor="#999999"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                                <ActivityIndicator IsRunning="True"
                                                   Color="#2E7D32"
                                                   HeightRequest="30"/>
                            </StackLayout>
                        </Frame>

                        <Frame BackgroundColor="White"
                               Padding="20"
                               CornerRadius="16"
                               HasShadow="False"
                               BorderColor="#F0F0F0">
                            <StackLayout Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">
                                    <Border Grid.Column="0"
                                            Stroke="#2E7D32"
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="#E8F5E9"
                                            Padding="6,3"
                                            HorizontalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="⏳" 
                                                   FontSize="11"
                                                   TextColor="#2E7D32"
                                                   VerticalOptions="Center"/>
                                            <Label Text="Documents" 
                                                   FontSize="11"
                                                   TextColor="#2E7D32"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Label Grid.Column="1" 
                                           Text="──────" 
                                           TextColor="#E0E0E0"
                                           FontSize="14"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Margin="5,0"/>
                                    <Border Grid.Column="2"
                                            Stroke="#E0E0E0"
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="White"
                                            Padding="6,3"
                                            HorizontalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="🛵" 
                                                   FontSize="11"
                                                   TextColor="#9E9E9E"
                                                   VerticalOptions="Center"/>
                                            <Label Text="Tricycle" 
                                                   FontSize="11"
                                                   TextColor="#9E9E9E"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Frame Grid.Column="0"
                                           BackgroundColor="#2E7D32"
                                           CornerRadius="12"
                                           Padding="8,4"
                                           HorizontalOptions="Start">
                                        <Label Text="Step 1/2"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                    </Frame>
                                    <Label Grid.Column="1"
                                           Text="Waiting for Document Approval"
                                           FontSize="13"
                                           TextColor="#2E7D32"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <Border Stroke="#E0E0E0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        HeightRequest="6"
                                        BackgroundColor="White">
                                    <Border Stroke="#2E7D32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            BackgroundColor="#2E7D32"
                                            WidthRequest="150"
                                            HorizontalOptions="Start"/>
                                </Border>
                                <Label Text="⏳ Your documents are being reviewed by admin"
                                       FontSize="11"
                                       TextColor="#666666"
                                       HorizontalOptions="Center"
                                       Margin="0,5,0,0"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- REJECTED VIEW -->
                    <StackLayout x:Name="RejectedView" IsVisible="False">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FFEBEE"
                                       HorizontalOptions="Center">
                                    <Label Text="❌"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Application Rejected"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           TextColor="#D32F2F" />
                                    <Label x:Name="RejectionReasonLabel"
                                           Text="Your documents did not meet the requirements."
                                           FontSize="14"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                                <BoxView HeightRequest="1" BackgroundColor="#FFCDD2" Margin="0,10"/>
                                <StackLayout Spacing="15" HorizontalOptions="Center">
                                    <Label Text="Please re-upload the required document:"
                                           FontSize="14"
                                           TextColor="#D32F2F"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                    <Button x:Name="ReuploadButton"
                                            Text="Re-upload Document"
                                            BackgroundColor="#EF4444"
                                            TextColor="White"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            CornerRadius="25"
                                            HeightRequest="50"
                                            WidthRequest="250"
                                            Clicked="OnReuploadClicked"/>
                                    <Label Text="Your document will be reviewed again within 24 hours."
                                           FontSize="12"
                                           TextColor="#999"
                                           HorizontalOptions="Center"/>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- SUSPENDED VIEW -->
                    <StackLayout x:Name="SuspendedView" IsVisible="False" Spacing="16">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FEF3C7"
                                       HorizontalOptions="Center">
                                    <Label Text="⏸️"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Account Suspended"
                                           FontAttributes="Bold"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="#F59E0B" />
                                    <Label x:Name="SuspendedMessageLabel"
                                           Text="Your account has been suspended by admin."
                                           FontSize="16"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label x:Name="SuspendedUntilLabel"
                                           Text=""
                                           FontSize="14"
                                           TextColor="#F59E0B"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                    <Label Text="You cannot go online or accept rides while suspended."
                                           FontSize="14"
                                           TextColor="#999999"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                                <Button Text="Contact Support"
                                        BackgroundColor="#F59E0B"
                                        TextColor="White"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        CornerRadius="25"
                                        HeightRequest="50"
                                        WidthRequest="250"
                                        Clicked="OnContactSupportClicked"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- DEACTIVATED VIEW -->
                    <StackLayout x:Name="DeactivatedView" IsVisible="False" Spacing="16">
                        <Frame BackgroundColor="White"
                               Padding="30"
                               CornerRadius="12">
                            <StackLayout Spacing="20" HorizontalOptions="Center">
                                <Frame CornerRadius="80"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       BackgroundColor="#FEE2E2"
                                       HorizontalOptions="Center">
                                    <Label Text="🚫"
                                           FontSize="45"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <StackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="Account Deactivated"
                                           FontAttributes="Bold"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="#EF4444" />
                                    <Label x:Name="DeactivatedMessageLabel"
                                           Text="Your account has been deactivated by admin."
                                           FontSize="16"
                                           TextColor="#666666"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="You can no longer use this account."
                                           FontSize="14"
                                           TextColor="#999999"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                                <Button Text="Contact Support"
                                        BackgroundColor="#EF4444"
                                        TextColor="White"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        CornerRadius="25"
                                        HeightRequest="50"
                                        WidthRequest="250"
                                        Clicked="OnContactSupportClicked"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>

                    <!-- APPROVED VIEW -->
                    <StackLayout x:Name="ApprovedView" IsVisible="False" Spacing="16">

                        <!-- TRICYCLE REJECTED SECTION -->
                        <StackLayout x:Name="TricycleRejectedSection" IsVisible="False" Spacing="16">
                            <Frame BackgroundColor="White"
                                   Padding="30"
                                   CornerRadius="12">
                                <StackLayout Spacing="20" HorizontalOptions="Center">
                                    <Frame CornerRadius="80"
                                           HeightRequest="100"
                                           WidthRequest="100"
                                           BackgroundColor="#FFEBEE"
                                           HorizontalOptions="Center">
                                        <Label Text="❌"
                                               FontSize="45"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <StackLayout Spacing="10" HorizontalOptions="Center">
                                        <Label Text="Tricycle Rejected"
                                               FontAttributes="Bold"
                                               FontSize="20"
                                               HorizontalOptions="Center"
                                               TextColor="#D32F2F" />
                                        <Label x:Name="TricycleRejectionReasonLabel"
                                               Text="Your tricycle details were rejected by admin."
                                               FontSize="14"
                                               TextColor="#666666"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center" />
                                        <Label Text="Please update your information and resubmit."
                                               FontSize="13"
                                               TextColor="#999999"
                                               HorizontalOptions="Center" />
                                    </StackLayout>
                                    <Button x:Name="TricycleRejectedEditButton"
                                            Text="Edit Tricycle Details"
                                            BackgroundColor="#D32F2F"
                                            TextColor="White"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            CornerRadius="25"
                                            HeightRequest="50"
                                            WidthRequest="250"
                                            Clicked="OnEditTricycleClicked"/>
                                </StackLayout>
                            </Frame>
                        </StackLayout>

                        <!-- TRICYCLE PENDING SECTION -->
                        <StackLayout x:Name="TricyclePendingSection" IsVisible="False" Spacing="16">
                            <Frame BackgroundColor="White"
                                   Padding="30"
                                   CornerRadius="12">
                                <StackLayout Spacing="20" HorizontalOptions="Center">
                                    <Frame CornerRadius="80"
                                           HeightRequest="100"
                                           WidthRequest="100"
                                           BackgroundColor="#FFF3E0"
                                           HorizontalOptions="Center">
                                        <Label Text="🛵"
                                               FontSize="45"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <StackLayout Spacing="10" HorizontalOptions="Center">
                                        <Label Text="Tricycle Pending Approval"
                                               FontAttributes="Bold"
                                               FontSize="20"
                                               HorizontalOptions="Center"
                                               TextColor="#F57C00" />
                                        <Label Text="Your tricycle details are being reviewed by admin."
                                               FontSize="14"
                                               TextColor="#666666"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center" />
                                        <Label Text="Complete your tricycle details to proceed."
                                               FontSize="13"
                                               TextColor="#999999"
                                               HorizontalOptions="Center" />
                                    </StackLayout>
                                    <Button x:Name="GoToEditTricycleButton"
                                            Text="Go to Edit Tricycle"
                                            BackgroundColor="#F57C00"
                                            TextColor="White"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            CornerRadius="25"
                                            HeightRequest="50"
                                            WidthRequest="250"
                                            Clicked="OnEditTricycleClicked"/>
                                </StackLayout>
                            </Frame>

                            <Frame BackgroundColor="White"
                                   Padding="20"
                                   CornerRadius="16"
                                   HasShadow="False"
                                   BorderColor="#F0F0F0">
                                <StackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">
                                        <Border Grid.Column="0"
                                                Stroke="#2E7D32"
                                                StrokeThickness="2"
                                                StrokeShape="RoundRectangle 20"
                                                BackgroundColor="#E8F5E9"
                                                Padding="6,3"
                                                HorizontalOptions="Center">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="✓" 
                                                       FontSize="12"
                                                       TextColor="#2E7D32"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"/>
                                                <Label Text="Documents" 
                                                       FontSize="11"
                                                       TextColor="#2E7D32"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Label Grid.Column="1" 
                                               Text="──────" 
                                               TextColor="#2E7D32"
                                               FontSize="14"
                                               Opacity="0.8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Margin="5,0"/>
                                        <Border Grid.Column="2"
                                                Stroke="#F57C00"
                                                StrokeThickness="3"
                                                StrokeShape="RoundRectangle 20"
                                                BackgroundColor="#FFF3E0"
                                                Padding="6,3"
                                                HorizontalOptions="Center">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⏳" 
                                                       FontSize="11"
                                                       TextColor="#F57C00"
                                                       VerticalOptions="Center"/>
                                                <Label Text="Tricycle" 
                                                       FontSize="11"
                                                       TextColor="#F57C00"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Frame Grid.Column="0"
                                               BackgroundColor="#F57C00"
                                               CornerRadius="12"
                                               Padding="8,4"
                                               HorizontalOptions="Start">
                                            <Label Text="Step 2/2"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                        </Frame>
                                        <Label Grid.Column="1"
                                               Text="Waiting for Tricycle Approval"
                                               FontSize="13"
                                               TextColor="#F57C00"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                    <Border Stroke="#E0E0E0"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="6"
                                            BackgroundColor="White">
                                        <Border Stroke="#F57C00"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 4"
                                                BackgroundColor="#F57C00"
                                                WidthRequest="300"
                                                HorizontalOptions="Start"/>
                                    </Border>
                                    <Label Text="⏳ ✓ Documents approved • Waiting for tricycle review"
                                           FontSize="11"
                                           TextColor="#F57C00"
                                           HorizontalOptions="Center"/>
                                </StackLayout>
                            </Frame>
                        </StackLayout>

                        <!-- FULL DASHBOARD SECTION -->
                        <StackLayout x:Name="FullDashboardSection" IsVisible="False" Spacing="16">

                            <Frame BackgroundColor="White"
                                   Padding="20"
                                   CornerRadius="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackLayout Spacing="8">
                                        <Label x:Name="GreetingLabel"
                                               Text="Good Evening!"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#2E7D32"/>
                                        <Label x:Name="DriverNameLabel"
                                               Text="Loading..."
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="#000000"/>
                                        <HorizontalStackLayout Spacing="6">
                                            <Image x:Name="Star1" Source="star_filled.png" WidthRequest="20" HeightRequest="20"/>
                                            <Image x:Name="Star2" Source="star_filled.png" WidthRequest="20" HeightRequest="20"/>
                                            <Image x:Name="Star3" Source="star_filled.png" WidthRequest="20" HeightRequest="20"/>
                                            <Image x:Name="Star4" Source="star_filled.png" WidthRequest="20" HeightRequest="20"/>
                                            <Image x:Name="Star5" Source="star_filled.png" WidthRequest="20" HeightRequest="20"/>
                                            <Label x:Name="RatingLabel" Text="5.0" FontSize="16" FontAttributes="Bold" 
                                                   TextColor="#FF9800" Margin="8,0,0,0"/>
                                        </HorizontalStackLayout>
                                    </StackLayout>
                                    <Frame Grid.Column="1" 
                                           BackgroundColor="#F8F9FA"
                                           BorderColor="#D1D5DB"
                                           CornerRadius="10"
                                           Padding="16"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Margin="8">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                                            <Label x:Name="OnlineStatusText"
                                                   Text="Online"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#2E7D32"
                                                   HorizontalOptions="Center"
                                                   LineBreakMode="TailTruncation"/>
                                            <Frame Grid.Row="1"
                                                   BackgroundColor="#D1D5DB"
                                                   BorderColor="Transparent"
                                                   CornerRadius="20"
                                                   WidthRequest="62"
                                                   HeightRequest="36"
                                                   HorizontalOptions="Center"
                                                   Padding="0">
                                                <Switch x:Name="ActiveSwitch"
                                                        IsToggled="True"
                                                        OnColor="#2E7D32"  
                                                        ThumbColor="White"
                                                        Toggled="OnActiveSwitchToggled"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        Scale="1.1"/>
                                            </Frame>
                                        </Grid>
                                    </Frame>
                                </Grid>
                            </Frame>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Frame BackgroundColor="White" Padding="16" CornerRadius="12">
                                    <StackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Frame BackgroundColor="#E8F5E9" Padding="12" CornerRadius="20" HorizontalOptions="Center">
                                            <Image Source="ride_icon.png" WidthRequest="24" HeightRequest="24"/>
                                        </Frame>
                                        <Label Text="TOTAL RIDES" FontSize="12" FontAttributes="Bold" TextColor="#666666" HorizontalOptions="Center"/>
                                        <Label x:Name="TotalRidesLabel" Text="0" FontSize="28" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                                            <Label Text="Today:" FontSize="11" TextColor="#666666"/>
                                            <Label x:Name="TodayRidesLabel" Text="0" FontSize="11" FontAttributes="Bold" TextColor="#0288D1"/>
                                        </HorizontalStackLayout>
                                    </StackLayout>
                                </Frame>
                                <Frame BackgroundColor="White" Padding="16" CornerRadius="12" Grid.Column="1">
                                    <StackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Frame BackgroundColor="#E3F2FD" Padding="12" CornerRadius="20" HorizontalOptions="Center">
                                            <Label Text="💰" FontSize="20"/>
                                        </Frame>
                                        <Label Text="TOTAL INCOME" FontSize="12" FontAttributes="Bold" TextColor="#666666" HorizontalOptions="Center"/>
                                        <Label x:Name="TotalEarningsLabel" Text="₱0" FontSize="24" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                                            <Label Text="Today:" FontSize="11" TextColor="#666666"/>
                                            <Label x:Name="TodayEarningsLabel" Text="₱0" FontSize="11" FontAttributes="Bold" TextColor="#FF9800"/>
                                        </HorizontalStackLayout>
                                    </StackLayout>
                                </Frame>
                            </Grid>

                            <StackLayout Spacing="10" Margin="0,20,0,0">
                                <Label Text="How to Use GoTryke" FontSize="16" FontAttributes="Bold" TextColor="Black"/>

                                <Frame x:Name="BannerFrame"
                                       HasShadow="True" 
                                       CornerRadius="15" 
                                       Padding="0" 
                                       BorderColor="#E0E0E0" 
                                       BackgroundColor="White" 
                                       HeightRequest="270">
                                    <Grid>
                                        <CarouselView x:Name="ImageCarousel" 
                                                      Loop="True" 
                                                      HeightRequest="300"
                                                      IsVisible="False">
                                            <CarouselView.ItemsLayout>
                                                <LinearItemsLayout Orientation="Horizontal" />
                                            </CarouselView.ItemsLayout>
                                            <CarouselView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Frame BackgroundColor="White" 
                                                               Padding="5" 
                                                               CornerRadius="10" 
                                                               HeightRequest="200" 
                                                               Margin="10,30,10,0">
                                                            <Frame.GestureRecognizers>
                                                                <TapGestureRecognizer Tapped="OnCarouselItemTapped"
                                                                                      CommandParameter="{Binding .}"/>
                                                            </Frame.GestureRecognizers>
                                                            <Image Source="{Binding ImageUrl}"
                                                                   Aspect="AspectFill"
                                                                   HorizontalOptions="Fill" 
                                                                   VerticalOptions="Fill"
                                                                   HeightRequest="200" 
                                                                   WidthRequest="310"/>
                                                        </Frame>
                                                        <Frame BackgroundColor="#2E7D32" 
                                                               Opacity="0.9" 
                                                               Padding="8,4" 
                                                               CornerRadius="10"
                                                               WidthRequest="190" 
                                                               HeightRequest="30" 
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Start" 
                                                               Margin="10,25,0,0">
                                                            <Label Text="{Binding Title}" 
                                                                   FontSize="12" 
                                                                   FontAttributes="Bold"
                                                                   TextColor="White" 
                                                                   HorizontalOptions="Center" 
                                                                   VerticalOptions="Center"/>
                                                        </Frame>
                                                    </Grid>
                                                </DataTemplate>
                                            </CarouselView.ItemTemplate>
                                        </CarouselView>

                                        <VerticalStackLayout x:Name="EmptyBannerContent" IsVisible="True" 
                                                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                            <Image Source="tricycle.png" HeightRequest="50" WidthRequest="50" Opacity="0.3"/>
                                            <Label x:Name="BannerStatusLabel" Text="No active banners" FontSize="14" TextColor="#666"/>
                                            <Label Text="Check back later for updates" FontSize="12" TextColor="#999"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>

                                <HorizontalStackLayout x:Name="IndicatorContainer" 
                                                       HorizontalOptions="Center" 
                                                       Spacing="8"/>
                            </StackLayout>

                            <Button x:Name="RideRequestButton"
                                    Text="View Ride Requests"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    BackgroundColor="#FFC107"
                                    CornerRadius="10"
                                    HeightRequest="48"
                                    Margin="0,16,0,0"
                                    Clicked="OnRideRequestClicked"
                                    IsVisible="True">
                                <Button.ImageSource>
                                    <FontImageSource Glyph="📋" Color="White" Size="18" />
                                </Button.ImageSource>
                            </Button>
                        </StackLayout>
                    </StackLayout>
                </StackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ACTIVE RIDE BANNER -->
        <Border x:Name="ActiveRideBanner"
                Grid.RowSpan="2"
                Padding="20"
                Margin="20"
                BackgroundColor="#FAFFFFFF"
                Stroke="#E0E0E0"
                StrokeShape="RoundRectangle 20"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                ZIndex="999"
                IsVisible="False">
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,4" Radius="12" />
            </Border.Shadow>

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnActiveRideBannerTapped"/>
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto,Auto" Padding="0" RowSpacing="8">

                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,0,0,5">
                    <Frame Grid.Column="0" 
                           x:Name="RideStatusBadge" 
                           BackgroundColor="#2E7D32" 
                           Padding="8,4" 
                           CornerRadius="8"
                           HorizontalOptions="Start">
                        <Label x:Name="RideStatusBadgeText" 
                               Text="Loading..." 
                               FontSize="10" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                    </Frame>
                    <Label Grid.Column="1" 
                           x:Name="RideStatusLabel" 
                           Text="Loading..." 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           TextColor="Black"
                           VerticalOptions="Center" 
                           HorizontalOptions="Start"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"/>
                    <Label Grid.Column="2" 
                           x:Name="RideTimeLabel" 
                           Text="-- mins" 
                           FontSize="12" 
                           TextColor="#666" 
                           VerticalOptions="Center" 
                           HorizontalOptions="End"/>
                </Grid>

                <Grid Grid.Row="1" 
                      ColumnDefinitions="Auto,*,Auto" 
                      ColumnSpacing="10" 
                      Margin="0,5,0,0">
                    <Frame Grid.Column="0"
                           BackgroundColor="#F0F9F0"
                           Padding="8"
                           CornerRadius="8"
                           HeightRequest="40"
                           WidthRequest="40"
                           VerticalOptions="Center">
                        <Image Source="tricycle.png"
                               HeightRequest="24"
                               WidthRequest="24"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                    </Frame>
                    <Grid Grid.Column="1" 
                          RowDefinitions="Auto,Auto" 
                          RowSpacing="2" 
                          VerticalOptions="Center">
                        <Label x:Name="PickupLabel"
                               Grid.Row="0"
                               Text="Loading address..."
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="Black"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Label x:Name="DropoffLabel"
                               Grid.Row="1"
                               Text="Loading address..."
                               FontSize="12"
                               TextColor="#666666"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                    </Grid>
                    <Frame Grid.Column="2"
                           BackgroundColor="#2E7D32"
                           Padding="10"
                           CornerRadius="8"
                           HeightRequest="40"
                           WidthRequest="40"
                           VerticalOptions="Center">
                        <Image Source="ride_icon.png"
                               HeightRequest="20"
                               WidthRequest="20"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                    </Frame>
                </Grid>
            </Grid>
        </Border>

        <!-- OFFLINE RESTRICTION MODAL -->
        <Frame x:Name="OfflineRestrictionModal"
               Grid.RowSpan="3"
               BackgroundColor="Black"
               Opacity="0.7"
               IsVisible="False"
               HasShadow="False"
               Padding="0"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseOfflineRestrictionModal"/>
            </Frame.GestureRecognizers>
        </Frame>

        <Frame x:Name="OfflineRestrictionContent"
               Grid.RowSpan="3"
               BackgroundColor="White"
               CornerRadius="20"
               Padding="0"
               WidthRequest="340"
               HeightRequest="600" 
               IsVisible="False"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <Grid RowDefinitions="Auto,*,Auto">
                <Frame BackgroundColor="#2E7D32" Padding="20" HasShadow="False">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Image Source="signal.png" HeightRequest="30" WidthRequest="30"/>
                        <Label Text="Active Ride Detected" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                    </HorizontalStackLayout>
                </Frame>
                <ScrollView Grid.Row="1" Padding="20">
                    <StackLayout Spacing="15">
                        <Frame BackgroundColor="#FFF3CD" CornerRadius="12" Padding="16">
                            <StackLayout Spacing="12">
                                <Label Text="⚠️ You cannot go offline" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#856404" 
                                       HorizontalOptions="Center"/>
                                <Label Text="You have an active ride in progress. Complete or cancel the ride first." 
                                       FontSize="14" 
                                       TextColor="#856404" 
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap"/>
                            </StackLayout>
                        </Frame>
                        <Frame BorderColor="#D1D5DB" CornerRadius="12" Padding="16">
                            <StackLayout Spacing="15">
                                <Label Text="Current Ride Details" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#2E7D32" 
                                       HorizontalOptions="Center"/>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Frame BackgroundColor="#E8F5E9" 
                                           Padding="8" 
                                           CornerRadius="8" 
                                           HeightRequest="40" 
                                           WidthRequest="40"
                                           VerticalOptions="Start">
                                        <Label Text="📍" 
                                               FontSize="18" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <StackLayout Grid.Column="1" Spacing="2">
                                        <Label x:Name="ModalPickupLabel" 
                                               Text="Loading..." 
                                               FontSize="14" 
                                               FontAttributes="Bold"
                                               TextColor="Black"
                                               LineBreakMode="WordWrap"/>
                                        <Label Text="Pickup Location" 
                                               FontSize="10" 
                                               TextColor="#666"/>
                                    </StackLayout>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Frame BackgroundColor="#E3F2FD" 
                                           Padding="8" 
                                           CornerRadius="8" 
                                           HeightRequest="40" 
                                           WidthRequest="40"
                                           VerticalOptions="Start">
                                        <Label Text="🎯" 
                                               FontSize="18" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <StackLayout Grid.Column="1" Spacing="2">
                                        <Label x:Name="ModalDropoffLabel" 
                                               Text="Loading..." 
                                               FontSize="14" 
                                               FontAttributes="Bold"
                                               TextColor="Black"
                                               LineBreakMode="WordWrap"/>
                                        <Label Text="Dropoff Location" 
                                               FontSize="10" 
                                               TextColor="#666"/>
                                    </StackLayout>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Frame BackgroundColor="#FFE5E5" 
                                           Padding="8" 
                                           CornerRadius="8" 
                                           HeightRequest="40" 
                                           WidthRequest="40">
                                        <Label Text="💰" 
                                               FontSize="18" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label x:Name="ModalFareLabel" 
                                               Text="₱0.00" 
                                               FontSize="16" 
                                               FontAttributes="Bold" 
                                               TextColor="#2E7D32"
                                               LineBreakMode="NoWrap"/>
                                        <Label Text="Fare Amount" 
                                               FontSize="10" 
                                               TextColor="#666"/>
                                    </StackLayout>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Frame x:Name="ModalStatusBadge" 
                                           BackgroundColor="#2E7D32" 
                                           Padding="8,4" 
                                           CornerRadius="8" 
                                           WidthRequest="40" 
                                           HeightRequest="40">
                                        <Label x:Name="ModalStatusText" 
                                               Text="✓" 
                                               FontSize="18" 
                                               TextColor="White" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label x:Name="ModalStatusLabel" 
                                               Text="ACCEPTED" 
                                               FontSize="14" 
                                               FontAttributes="Bold" 
                                               TextColor="#2E7D32"
                                               LineBreakMode="WordWrap"/>
                                        <Label Text="Current Status" 
                                               FontSize="10" 
                                               TextColor="#666"/>
                                    </StackLayout>
                                </Grid>
                            </StackLayout>
                        </Frame>
                    </StackLayout>
                </ScrollView>
                <Frame Grid.Row="2" BackgroundColor="#F8F9FA" Padding="20" HasShadow="False">
                    <Button x:Name="ModalActionButton" 
                            Text="VIEW RIDE DETAILS" 
                            TextColor="White" 
                            FontAttributes="Bold"
                            FontSize="16" 
                            BackgroundColor="#2E7D32" 
                            CornerRadius="10" 
                            HeightRequest="48"
                            Clicked="OnViewRideDetailsClicked"/>
                </Frame>
            </Grid>
        </Frame>

        <!-- TRICYCLE PENDING MODAL -->
        <Frame x:Name="TricyclePendingModal"
               Grid.RowSpan="3"
               BackgroundColor="Black"
               Opacity="0.7"
               IsVisible="False"
               HasShadow="False"
               Padding="0"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseTricyclePendingModal"/>
            </Frame.GestureRecognizers>
        </Frame>

        <Frame x:Name="TricyclePendingContent"
               Grid.RowSpan="3"
               BackgroundColor="White"
               CornerRadius="25"
               Padding="0"
               WidthRequest="340"
               HeightRequest="430"
               IsVisible="False"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">
            <StackLayout Spacing="0">
                <Frame BackgroundColor="#FF9800"
                       Padding="25,20"
                       HasShadow="False">
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="⏳"
                               FontSize="40"
                               TextColor="White"/>
                        <Label Text="Pending Approval"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>
                <StackLayout Padding="25,30" Spacing="25">
                    <Label x:Name="TricyclePendingMessage"
                           Text="Your tricycle details are pending admin approval."
                           FontSize="16"
                           TextColor="#333333"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"/>
                    <Label Text="You'll be able to go online once approved."
                           FontSize="14"
                           TextColor="#666666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Frame BackgroundColor="#FFF3E0"
                           CornerRadius="12"
                           Padding="15"
                           HasShadow="False">
                        <StackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="⏱️"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                                <Label Text="Estimated time: 24-48 hours"
                                       FontSize="14"
                                       TextColor="#E65100"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="📋"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                                <Label Text="You'll be notified when approved"
                                       FontSize="14"
                                       TextColor="#E65100"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </StackLayout>
                    </Frame>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                        <Button x:Name="TricyclePendingCloseButton"
                                Grid.Column="0"
                                Text="Close"
                                BackgroundColor="#F5F5F5"
                                TextColor="#666666"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                Clicked="OnCloseTricyclePendingModal"/>
                        <Button x:Name="TricyclePendingEditButton"
                                Grid.Column="1"
                                Text="Edit Details"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                Clicked="OnEditTricycleClicked"/>
                    </Grid>
                </StackLayout>
            </StackLayout>
        </Frame>

        <!-- MISSING REQUIREMENTS MODAL -->
        <Frame x:Name="MissingRequirementsModal"
               Grid.RowSpan="3"
               BackgroundColor="Black"
               Opacity="0.7"
               IsVisible="False"
               HasShadow="False"
               Padding="0"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseMissingRequirementsModal"/>
            </Frame.GestureRecognizers>
        </Frame>

        <Frame x:Name="MissingRequirementsContent"
               Grid.RowSpan="3"
               BackgroundColor="White"
               CornerRadius="25"
               Padding="0"
               WidthRequest="340"
               HeightRequest="430"
               IsVisible="False"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">
            <StackLayout Spacing="0">
                <Frame BackgroundColor="#EF4444"
                       Padding="25,20"
                       HasShadow="False">
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="⚠️"
                               FontSize="40"
                               TextColor="White"/>
                        <Label Text="Missing Requirements"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>
                <StackLayout Padding="25,25" Spacing="20">
                    <Label x:Name="MissingRequirementsMessage"
                           Text="You cannot go online because:"
                           FontSize="15"
                           TextColor="#333333"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Frame BackgroundColor="#FEF2F2"
                           CornerRadius="12"
                           Padding="15"
                           HasShadow="False">
                        <StackLayout x:Name="RequirementsList" Spacing="12"/>
                    </Frame>
                    <Label Text="Please complete these requirements first."
                           FontSize="13"
                           TextColor="#666666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                        <Button x:Name="MissingRequirementsCloseButton"
                                Grid.Column="0"
                                Text="Later"
                                BackgroundColor="#F5F5F5"
                                TextColor="#666666"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                Clicked="OnCloseMissingRequirementsModal"/>
                        <Button x:Name="MissingRequirementsEditButton"
                                Grid.Column="1"
                                Text="Edit Now"
                                BackgroundColor="#EF4444"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                Clicked="OnEditTricycleClicked"/>
                    </Grid>
                </StackLayout>
            </StackLayout>
        </Frame>

        <!-- ACCOUNT RESTRICTED MODAL -->
        <Frame x:Name="AccountRestrictedModal"
               Grid.RowSpan="3"
               BackgroundColor="Black"
               Opacity="0.7"
               IsVisible="False"
               HasShadow="False"
               Padding="0"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseAccountRestrictedModal"/>
            </Frame.GestureRecognizers>
        </Frame>

        <Frame x:Name="AccountRestrictedContent"
               Grid.RowSpan="3"
               BackgroundColor="White"
               CornerRadius="25"
               Padding="0"
               WidthRequest="340"
               HeightRequest="430"
               IsVisible="False"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">
            <StackLayout Spacing="0">
                <Frame x:Name="AccountRestrictedHeader"
                       Padding="25,20"
                       HasShadow="False">
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label x:Name="AccountRestrictedIcon"
                               FontSize="40"
                               TextColor="White"/>
                        <Label x:Name="AccountRestrictedTitle"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>
                <StackLayout Padding="25,30" Spacing="20">
                    <Label x:Name="AccountRestrictedMessage"
                           Text=""
                           FontSize="16"
                           TextColor="#333333"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"/>
                    <Label x:Name="AccountRestrictedUntilLabel"
                           Text=""
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#F59E0B"
                           HorizontalOptions="Center"
                           IsVisible="False"/>
                    <Label x:Name="AccountRestrictedInfo"
                           Text=""
                           FontSize="14"
                           TextColor="#666666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                        <Button x:Name="AccountRestrictedCloseButton"
                                Grid.Column="0"
                                Text="Close"
                                BackgroundColor="#F5F5F5"
                                TextColor="#666666"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                Clicked="OnCloseAccountRestrictedModal"/>
                        <Button x:Name="AccountRestrictedSupportButton"
                                Grid.Column="1"
                                Text="Contact Support"
                                BackgroundColor="#F59E0B"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                Clicked="OnContactSupportClicked"/>
                    </Grid>
                </StackLayout>
            </StackLayout>
        </Frame>

        <!-- TRICYCLE APPROVED MODAL -->
        <Frame x:Name="TricycleApprovedModal"
               Grid.RowSpan="3"
               BackgroundColor="Black"
               Opacity="0.7"
               IsVisible="False"
               HasShadow="False"
               Padding="0"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseTricycleApprovedModal"/>
            </Frame.GestureRecognizers>
        </Frame>

        <Frame x:Name="TricycleApprovedContent"
               Grid.RowSpan="3"
               BackgroundColor="White"
               CornerRadius="25"
               Padding="0"
               WidthRequest="340"
               HeightRequest="530"
               IsVisible="False"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">
            <StackLayout Spacing="0">
                <Frame BackgroundColor="#4CAF50" HasShadow="False" Padding="25,20">
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="Account Approved!"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>
                <StackLayout Padding="25,30" Spacing="20">
                    <Frame BackgroundColor="#E8F5E9"
                           CornerRadius="60"
                           Padding="15"
                           WidthRequest="100"
                           HeightRequest="100"
                           HorizontalOptions="Center"
                           HasShadow="False">
                        <Label Text="🎉"
                               FontSize="50"
                               TextColor="#4CAF50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>
                    <Label x:Name="TricycleApprovedMessage"
                           Text="Your tricycle has been approved!"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"/>
                    <Label Text="You can now go online and start accepting rides."
                           FontSize="14"
                           TextColor="#666666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Frame BackgroundColor="#F5F5F5"
                           CornerRadius="12"
                           Padding="15"
                           HasShadow="False">
                        <StackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🟢"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="Go Online anytime"
                                       FontSize="13"
                                       TextColor="#333333"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🟢"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="Accept ride requests"
                                       FontSize="13"
                                       TextColor="#333333"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🟢"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="View your dashboard"
                                       FontSize="13"
                                       TextColor="#333333"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </StackLayout>
                    </Frame>
                    <Button x:Name="TricycleApprovedButton"
                            Text="GO TO DASHBOARD"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="50"
                            WidthRequest="250"
                            HorizontalOptions="Center"
                            Clicked="OnCloseTricycleApprovedModal"/>
                </StackLayout>
            </StackLayout>
        </Frame>

    </Grid>
</ContentPage>