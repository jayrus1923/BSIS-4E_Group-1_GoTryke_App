<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Commuter_Payment"
             Title="Complete Payment"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="RootGrid">

        <!-- MAIN CONTENT -->
        <ScrollView x:Name="MainScrollView">
            <VerticalStackLayout Spacing="20" Padding="16">

                <!-- GoTryke Logo Header -->
                <Frame BackgroundColor="Transparent" 
                       CornerRadius="0" 
                       Padding="10"
                       HasShadow="False">
                    <HorizontalStackLayout HorizontalOptions="Center">
                        <Image Source="gotryke_logo.png"
                               HeightRequest="200"
                               WidthRequest="200"
                               Margin="0,-80,0,-77"
                               Aspect="AspectFit"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Payment Status Banner -->
                <Frame x:Name="PaymentStatusBanner"
                       BackgroundColor="#E8F5E9" 
                       CornerRadius="15" 
                       Padding="15"
                       HasShadow="True">
                    <HorizontalStackLayout Spacing="10">
                        <Frame x:Name="StatusIconFrame"
                               BackgroundColor="#4CAF50"
                               CornerRadius="8" 
                               Padding="10"
                               WidthRequest="40"
                               HeightRequest="40">
                            <Label x:Name="PaymentStatusIcon"
                                   Text="💳" 
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="PaymentStatusLabel"
                                   Text="COMPLETE YOUR PAYMENT" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   TextColor="#2E7D32"/>
                            <Label x:Name="PaymentStatusSubtitle"
                                   Text="Select payment method and rate driver" 
                                   FontSize="12" 
                                   TextColor="#666666"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Trip Details -->
                <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="📍 ROUTE" FontSize="14" FontAttributes="Bold" TextColor="#2E7D32"/>
                        <Label x:Name="RideIdLabel" Text="Loading..." FontSize="12" TextColor="#666666"/>

                        <!-- Pickup -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Frame BackgroundColor="#E8F5E9"
                                   Padding="12"
                                   CornerRadius="12"
                                   HeightRequest="48"
                                   WidthRequest="48"
                                   VerticalOptions="Center"
                                   HasShadow="False">
                                <Image Source="pickup.png"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Frame>

                            <VerticalStackLayout Grid.Column="1" 
                                                 Spacing="3"
                                                 VerticalOptions="Center">
                                <Label Text="FROM"
                                       FontSize="10"
                                       TextColor="#666666"
                                       FontAttributes="Bold"/>
                                <Label x:Name="PickupLabel"
                                       Text="Loading..."
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Dotted Line -->
                        <Grid Margin="23,2,0,2"
                              HeightRequest="30"
                              WidthRequest="20">
                            <VerticalStackLayout Spacing="3"
                                                 HorizontalOptions="Center">
                                <BoxView HeightRequest="4"
                                         WidthRequest="4"
                                         BackgroundColor="#CCCCCC"
                                         CornerRadius="2"/>
                                <BoxView HeightRequest="4"
                                         WidthRequest="4"
                                         BackgroundColor="#CCCCCC"
                                         CornerRadius="2"/>
                                <BoxView HeightRequest="4"
                                         WidthRequest="4"
                                         BackgroundColor="#CCCCCC"
                                         CornerRadius="2"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Dropoff -->
                        <Grid ColumnDefinitions="Auto,*,Auto" 
                              ColumnSpacing="12"
                              Margin="0,0,0,0">

                            <Frame BackgroundColor="#FFEBEE"
                                   Padding="12"
                                   CornerRadius="12"
                                   HeightRequest="48"
                                   WidthRequest="48"
                                   VerticalOptions="Center"
                                   HasShadow="False">
                                <Image Source="dropoff.png"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Frame>

                            <VerticalStackLayout Grid.Column="1" 
                                                 Spacing="3"
                                                 VerticalOptions="Center">
                                <Label Text="TO"
                                       FontSize="10"
                                       TextColor="#666666"
                                       FontAttributes="Bold"/>
                                <Label x:Name="DropoffLabel"
                                       Text="Loading..."
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Driver Info -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,15,0,0">
                            <Frame Grid.Column="0"
                                   BackgroundColor="White"
                                   Padding="0"
                                   CornerRadius="35"
                                   HeightRequest="70"
                                   WidthRequest="70"
                                   HasShadow="True"
                                   BorderColor="#E0E0E0">
                                <Image x:Name="DriverImage"
                                       Source="profile_icon.png"
                                       Aspect="AspectFill"
                                       HeightRequest="70"
                                       WidthRequest="70">
                                    <Image.Clip>
                                        <EllipseGeometry Center="35,35"
                                                         RadiusX="35"
                                                         RadiusY="35"/>
                                    </Image.Clip>
                                </Image>
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" 
                                                 Spacing="6"
                                                 VerticalOptions="Center">
                                <Label x:Name="DriverNameLabel" 
                                       Text="Driver" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="Black"/>
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="star_filled.png"
                                           HeightRequest="14"
                                           WidthRequest="14"/>
                                    <Label x:Name="DriverRatingLabel" 
                                           Text="5.0" 
                                           FontSize="13" 
                                           TextColor="#666666"/>
                                    <Label Text="•" FontSize="13" TextColor="#999999"/>
                                    <Label x:Name="DriverRidesLabel" 
                                           Text="0 rides" 
                                           FontSize="13" 
                                           TextColor="#666666"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Fare Summary -->
                <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="💰 FARE SUMMARY" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Padding="0,10">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="DISTANCE" FontSize="12" TextColor="#666666"/>
                                <Label x:Name="DistanceLabel" 
                                       Text="0 km" 
                                       FontSize="14" 
                                       TextColor="Black" 
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                <Label Text="DURATION" FontSize="12" TextColor="#666666"/>
                                <Label x:Name="DurationLabel" 
                                       Text="0 mins" 
                                       FontSize="14" 
                                       TextColor="Black" 
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,5"/>

                        <!-- Total Fare -->
                        <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                            <Label Text="TOTAL FARE" 
                                   FontSize="12" 
                                   TextColor="#666666" 
                                   HorizontalOptions="Center"/>
                            <Label x:Name="TotalFareLabel" 
                                   Text="₱0" 
                                   FontSize="36" 
                                   FontAttributes="Bold" 
                                   TextColor="#2E7D32" 
                                   HorizontalOptions="Center"/>
                            <Label Text="Inclusive of all charges" 
                                   FontSize="11" 
                                   TextColor="#999999" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Payment Method -->
                <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="💳 PAYMENT METHOD" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                        <!-- Selected Payment Display -->
                        <Frame x:Name="SelectedPaymentFrame"
                               BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="True"
                               BorderColor="#E0E0E0"
                               HeightRequest="80">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Frame x:Name="SelectedPaymentIconFrame"
                                       BackgroundColor="#E8F5E9"
                                       CornerRadius="10" 
                                       Padding="12"
                                       HeightRequest="44"
                                       WidthRequest="44"
                                       VerticalOptions="Center">
                                    <Image x:Name="SelectedPaymentIcon"
                                           Source="cash.png"
                                           HeightRequest="20"
                                           WidthRequest="20"
                                           Aspect="AspectFit"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" 
                                                     Spacing="2" 
                                                     Padding="15,0"
                                                     VerticalOptions="Center">
                                    <Label x:Name="SelectedPaymentLabel"
                                           Text="Select Payment"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label x:Name="SelectedPaymentDescription"
                                           Text="Tap to change payment method"
                                           FontSize="12"
                                           TextColor="#666666"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="2"
                                        Text="Change"
                                        BackgroundColor="Transparent"
                                        TextColor="#2196F3"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        Padding="10,0"
                                        VerticalOptions="Center"
                                        Clicked="OnChangePaymentClicked"/>
                            </Grid>
                        </Frame>

                        <!-- GCASH QR CODE SECTION -->
                        <Frame x:Name="QrCodeFrame"
                               BackgroundColor="#FFFFFF"
                               CornerRadius="15"
                               Padding="20"
                               HasShadow="True"
                               BorderColor="#E0E0E0"
                               IsVisible="False">
                            <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                                <Label Text="📱 SCAN TO PAY VIA GCASH" 
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="#333333"
                                       HorizontalOptions="Center"/>

                                <Frame BackgroundColor="White"
                                       CornerRadius="12"
                                       Padding="15"
                                       BorderColor="#E0E0E0"
                                       HasShadow="True"
                                       HorizontalOptions="Center">
                                    <Image x:Name="QrCodeImage"
                                           HeightRequest="200"
                                           WidthRequest="200"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnQrCodeTapped"/>
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Frame>

                                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                    <Label Text="1. Open GCash app" 
                                           FontSize="12" 
                                           TextColor="#666666"/>
                                    <Label Text="2. Tap 'Scan QR'" 
                                           FontSize="12" 
                                           TextColor="#666666"/>
                                    <Label Text="3. Scan the code above" 
                                           FontSize="12" 
                                           TextColor="#666666"/>
                                    <Label x:Name="QrInstructionsLabel"
                                           Text="4. Enter ₱0 and confirm" 
                                           FontSize="12" 
                                           TextColor="#666666"/>
                                </VerticalStackLayout>

                                <Frame x:Name="QrStatusFrame"
                                       BackgroundColor="#E8F5E9"
                                       CornerRadius="8"
                                       Padding="10,5"
                                       IsVisible="False">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label x:Name="QrStatusLabel"
                                               Text="Driver's GCash QR Code Ready"
                                               FontSize="11"
                                               TextColor="#2E7D32"/>
                                    </HorizontalStackLayout>
                                </Frame>

                                <Button x:Name="DownloadQrButton"
                                        Text="📥 DOWNLOAD QR CODE"
                                        BackgroundColor="#2196F3"
                                        TextColor="White"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        CornerRadius="8"
                                        HeightRequest="45"
                                        Clicked="OnDownloadQrClicked"
                                        IsVisible="False"/>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Payment Sent Status -->
                        <Frame x:Name="PaymentSentFrame"
                               BackgroundColor="#E8F5E9"
                               CornerRadius="12"
                               Padding="15"
                               IsVisible="False">
                            <VerticalStackLayout Spacing="5">
                                <HorizontalStackLayout Spacing="10">
                                    <Frame BackgroundColor="#4CAF50" 
                                           CornerRadius="8" 
                                           Padding="10"
                                           WidthRequest="40"
                                           HeightRequest="40">
                                        <Label Text="⏳" 
                                               FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Payment Sent" 
                                               FontSize="13" 
                                               FontAttributes="Bold"
                                               TextColor="#2E7D32"/>
                                        <Label x:Name="PaymentSentMessage"
                                               Text="Waiting for driver confirmation" 
                                               FontSize="11" 
                                               TextColor="#666666"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Label x:Name="PaymentSentTimeLabel"
                                       Text=""
                                       FontSize="11"
                                       TextColor="#666666"
                                       HorizontalOptions="Center"
                                       IsVisible="False"/>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Rate Driver -->
                <Frame x:Name="RatingFrame"
                       BackgroundColor="White" 
                       CornerRadius="15" 
                       Padding="20"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="⭐ RATE YOUR DRIVER" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>

                        <Label Text="How was your ride experience?" 
                               FontSize="13" 
                               TextColor="#666666"
                               HorizontalOptions="Center"/>

                        <!-- Stars -->
                        <HorizontalStackLayout x:Name="StarsLayout" 
                                               Spacing="8" 
                                               HorizontalOptions="Center">
                            <Frame x:Name="Star1" 
                                   BackgroundColor="Transparent" 
                                   Padding="0" 
                                   CornerRadius="10">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1"/>
                                </Frame.GestureRecognizers>
                                <Image Source="star_outline.png"
                                       HeightRequest="40"
                                       WidthRequest="40"/>
                            </Frame>
                            <Frame x:Name="Star2" 
                                   BackgroundColor="Transparent" 
                                   Padding="0" 
                                   CornerRadius="10">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2"/>
                                </Frame.GestureRecognizers>
                                <Image Source="star_outline.png"
                                       HeightRequest="40"
                                       WidthRequest="40"/>
                            </Frame>
                            <Frame x:Name="Star3" 
                                   BackgroundColor="Transparent" 
                                   Padding="0" 
                                   CornerRadius="10">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3"/>
                                </Frame.GestureRecognizers>
                                <Image Source="star_outline.png"
                                       HeightRequest="40"
                                       WidthRequest="40"/>
                            </Frame>
                            <Frame x:Name="Star4" 
                                   BackgroundColor="Transparent" 
                                   Padding="0" 
                                   CornerRadius="10">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4"/>
                                </Frame.GestureRecognizers>
                                <Image Source="star_outline.png"
                                       HeightRequest="40"
                                       WidthRequest="40"/>
                            </Frame>
                            <Frame x:Name="Star5" 
                                   BackgroundColor="Transparent" 
                                   Padding="0" 
                                   CornerRadius="10">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5"/>
                                </Frame.GestureRecognizers>
                                <Image Source="star_outline.png"
                                       HeightRequest="40"
                                       WidthRequest="40"/>
                            </Frame>
                        </HorizontalStackLayout>

                        <Label x:Name="RatingText" 
                               Text="Tap stars to rate" 
                               FontSize="13" 
                               TextColor="#666666" 
                               HorizontalOptions="Center"/>

                        <!-- Rating Feedback Buttons -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">
                            <Button x:Name="PoorButton"
                                    Text="Poor"
                                    Grid.Column="0"
                                    BackgroundColor="#F5F5F5"
                                    TextColor="#666666"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Clicked="OnPoorButtonClicked"/>
                            <Button x:Name="AverageButton"
                                    Text="Average"
                                    Grid.Column="1"
                                    BackgroundColor="#F5F5F5"
                                    TextColor="#666666"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Clicked="OnAverageButtonClicked"/>
                            <Button x:Name="ExcellentButton"
                                    Text="Excellent"
                                    Grid.Column="2"
                                    BackgroundColor="#F5F5F5"
                                    TextColor="#666666"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Clicked="OnExcellentButtonClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Action Buttons -->
                <VerticalStackLayout Spacing="10" Padding="0,10">
                    <Button x:Name="PayButton" 
                            Text="CONFIRM PAYMENT"
                            BackgroundColor="#E0E0E0"
                            TextColor="#999999"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="12"
                            HeightRequest="55"
                            Clicked="OnPayButtonClicked"
                            IsEnabled="False"/>

                    <Button x:Name="SkipRatingButton"
                            Text="PAY WITHOUT RATING"
                            BackgroundColor="Transparent"
                            TextColor="#666666"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="45"
                            Clicked="OnSkipRatingClicked"/>
                </VerticalStackLayout>

                <!-- Real-time Status Bar -->
                <Frame x:Name="RealtimeStatusFrame"
                       BackgroundColor="#F0F9F0" 
                       CornerRadius="12" 
                       Padding="15,10"
                       HasShadow="True"
                       IsVisible="False">
                    <HorizontalStackLayout Spacing="10">
                        <ActivityIndicator x:Name="RealtimeStatusIndicator"
                                           IsRunning="True" 
                                           Color="#2E7D32"
                                           WidthRequest="16"
                                           HeightRequest="16"/>
                        <Label x:Name="RealtimeStatusText"
                               Text="Waiting for driver confirmation..."
                               FontSize="12"
                               TextColor="#2E7D32"
                               VerticalOptions="Center"
                               HorizontalOptions="StartAndExpand"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Payment Confirmed View -->
                <Frame x:Name="PaymentConfirmedFrame"
                       BackgroundColor="#E8F5E9"
                       CornerRadius="15"
                       Padding="20"
                       HasShadow="True"
                       IsVisible="False">
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Frame BackgroundColor="#4CAF50" 
                               CornerRadius="50" 
                               Padding="20"
                               WidthRequest="80"
                               HeightRequest="80">
                            <Label Text="✅" 
                                   FontSize="30"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>

                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="PAYMENT CONFIRMED!" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"/>
                            <Label x:Name="ConfirmedAmountLabel"
                                   Text="₱0" 
                                   FontSize="24" 
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"/>
                            <Label Text="Driver has confirmed payment" 
                                   FontSize="13" 
                                   TextColor="#666666"/>
                            <Label x:Name="PaymentConfirmedTimeLabel"
                                   Text=""
                                   FontSize="11"
                                   TextColor="#666666"
                                   IsVisible="False"/>
                        </VerticalStackLayout>

                        <Button Text="RETURN TO HOME"
                                BackgroundColor="#2E7D32"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="15"
                                CornerRadius="12"
                                HeightRequest="50"
                                WidthRequest="200"
                                Clicked="OnReturnHomeClicked"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- LOADING OVERLAY - ILAGAY SA LIKOD PARA MAG-OVERLAY -->
        <Grid x:Name="LoadingOverlay"
              BackgroundColor="#80000000"
              IsVisible="False"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand"
              InputTransparent="True">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                <Frame BackgroundColor="White"
                       CornerRadius="20"
                       Padding="30"
                       WidthRequest="200"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True" Color="#2E7D32" HeightRequest="50" WidthRequest="50"/>
                        <Label Text="Processing..." 
                               TextColor="#2E7D32" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </Grid>

        <!-- FULL SCREEN QR CODE MODAL -->
        <Grid x:Name="FullScreenQrGrid"
              BackgroundColor="#000000"
              IsVisible="False"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand"
              InputTransparent="False">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseFullScreenClicked"/>
            </Grid.GestureRecognizers>

            <Frame BackgroundColor="White"
                   CornerRadius="20"
                   Padding="20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   HasShadow="True">
                <Image x:Name="FullScreenQrImage"
                       HeightRequest="300"
                       WidthRequest="300"
                       Aspect="AspectFit"/>
            </Frame>

            <Label Text="Tap anywhere to close"
                   TextColor="#80FFFFFF"
                   FontSize="12"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,30"/>
        </Grid>

    </Grid>
</ContentPage>