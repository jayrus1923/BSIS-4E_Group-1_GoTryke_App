<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Driver_EmailOTP"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid RowSpacing="0" ColumnSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                StrokeThickness="0"
                Padding="20,15"
                BackgroundColor="#2E7D32">
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="12" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Image Source="white_back.png" 
                       HeightRequest="22" 
                       WidthRequest="22"
                       VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackButtonClicked"/>
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="Verify New Email" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" BackgroundColor="#F8F9FA">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Frame BackgroundColor="#E8F5E9" 
                       CornerRadius="12" 
                       Padding="15" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📧 Email Verification" 
                               FontSize="15" 
                               FontAttributes="Bold" 
                               TextColor="#2E7D32"/>
                        <Label Text="We've sent a 6-digit code to" 
                               FontSize="13" 
                               TextColor="#666666"/>
                        <Label x:Name="EmailLabel"
                               Text="email@example.com"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#2E7D32"/>
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="Enter the code"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#2E7D32"
                           HorizontalOptions="Center"/>

                    <Grid HorizontalOptions="Center" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Otp1Border"
                                Grid.Column="0"
                                Stroke="#CCCCCC"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Background="#F5F5F5"
                                HeightRequest="55"
                                WidthRequest="50">
                            <Entry x:Name="Otp1"
                                   BackgroundColor="Transparent"
                                   TextColor="Black"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Keyboard="Numeric"
                                   MaxLength="1"
                                   IsReadOnly="True"
                                   IsVisible="True"/>
                        </Border>

                        <Border x:Name="Otp2Border"
                                Grid.Column="1"
                                Stroke="#CCCCCC"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Background="#F5F5F5"
                                HeightRequest="55"
                                WidthRequest="50">
                            <Entry x:Name="Otp2"
                                   BackgroundColor="Transparent"
                                   TextColor="Black"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Keyboard="Numeric"
                                   MaxLength="1"
                                   IsReadOnly="True"
                                   IsVisible="True"/>
                        </Border>

                        <Border x:Name="Otp3Border"
                                Grid.Column="2"
                                Stroke="#CCCCCC"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Background="#F5F5F5"
                                HeightRequest="55"
                                WidthRequest="50">
                            <Entry x:Name="Otp3"
                                   BackgroundColor="Transparent"
                                   TextColor="Black"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Keyboard="Numeric"
                                   MaxLength="1"
                                   IsReadOnly="True"
                                   IsVisible="True"/>
                        </Border>

                        <Border x:Name="Otp4Border"
                                Grid.Column="3"
                                Stroke="#CCCCCC"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Background="#F5F5F5"
                                HeightRequest="55"
                                WidthRequest="50">
                            <Entry x:Name="Otp4"
                                   BackgroundColor="Transparent"
                                   TextColor="Black"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Keyboard="Numeric"
                                   MaxLength="1"
                                   IsReadOnly="True"
                                   IsVisible="True"/>
                        </Border>

                        <Border x:Name="Otp5Border"
                                Grid.Column="4"
                                Stroke="#CCCCCC"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Background="#F5F5F5"
                                HeightRequest="55"
                                WidthRequest="50">
                            <Entry x:Name="Otp5"
                                   BackgroundColor="Transparent"
                                   TextColor="Black"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Keyboard="Numeric"
                                   MaxLength="1"
                                   IsReadOnly="True"
                                   IsVisible="True"/>
                        </Border>

                        <Border x:Name="Otp6Border"
                                Grid.Column="5"
                                Stroke="#CCCCCC"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Background="#F5F5F5"
                                HeightRequest="55"
                                WidthRequest="50">
                            <Entry x:Name="Otp6"
                                   BackgroundColor="Transparent"
                                   TextColor="Black"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Keyboard="Numeric"
                                   MaxLength="1"
                                   IsReadOnly="True"
                                   IsVisible="True"/>
                        </Border>
                    </Grid>

                    <Label x:Name="OtpStatusLabel" 
                           Text="Enter 6-digit code"
                           FontSize="14"
                           TextColor="#2E7D32"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <StackLayout Spacing="8" HorizontalOptions="Center">
                    <Label x:Name="TimerLabel" 
                           TextColor="#666666" 
                           FontSize="13" 
                           IsVisible="False" 
                           HorizontalOptions="Center"/>
                    <Label x:Name="ResendLabel" 
                           HorizontalOptions="Center" 
                           FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Didn't receive the code? " TextColor="#666666"/>
                                <Span Text="Resend OTP" TextColor="#2E7D32" FontAttributes="Bold">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="ResendOTP"/>
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </StackLayout>

                <VerticalStackLayout x:Name="MessageStack" 
                                     Spacing="10" 
                                     HorizontalOptions="Center" 
                                     IsVisible="False">
                    <Border x:Name="SuccessMessage"
                            StrokeThickness="0"
                            BackgroundColor="#E8F5E9"
                            StrokeShape="RoundRectangle 12"
                            Padding="15,10"
                            IsVisible="False">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="✓"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"
                                   VerticalOptions="Center"/>
                            <Label x:Name="SuccessMessageLabel"
                                   Text="OTP verified successfully!"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border x:Name="ErrorMessage"
                            StrokeThickness="0"
                            BackgroundColor="#FFEBEE"
                            StrokeShape="RoundRectangle 12"
                            Padding="15,10"
                            IsVisible="False">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="✗"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#DC3545"
                                   VerticalOptions="Center"/>
                            <Label x:Name="ErrorMessageLabel"
                                   Text="Invalid OTP"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#DC3545"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Grid x:Name="ProcessingOverlay" 
                      IsVisible="False"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="15" 
                                        HorizontalOptions="Center" 
                                        VerticalOptions="Center">
                        <ActivityIndicator x:Name="ProcessingIndicator"
                                           Color="#2E7D32"
                                           IsRunning="False"
                                           HeightRequest="40"
                                           WidthRequest="40"/>
                        <Label x:Name="ProcessingLabel"
                               Text="Verifying..."
                               FontSize="14"
                               TextColor="#2E7D32"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="10,0,10,20">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="Num1" Text="1" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="1" x:Name="Num2" Text="2" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="2" x:Name="Num3" Text="3" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="Num4" Text="4" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="1" x:Name="Num5" Text="5" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="2" x:Name="Num6" Text="6" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="Num7" Text="7" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="1" x:Name="Num8" Text="8" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="2" x:Name="Num9" Text="9" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="ClearButton" Text="Clear" FontSize="18" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="#666666" Clicked="OnClearClicked"/>
                    <Button Grid.Column="1" x:Name="Num0" Text="0" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="Black" Clicked="OnNumberClicked"/>
                    <Button Grid.Column="2" x:Name="BackspaceButton" Text="⌫" FontSize="24" FontAttributes="Bold" CornerRadius="10" HeightRequest="60" BackgroundColor="#F8F9FA" TextColor="#666666" Clicked="OnBackspaceClicked"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>