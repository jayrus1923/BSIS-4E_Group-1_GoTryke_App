<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ServiceCo.Commuter_ChangePIN"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid RowSpacing="0" ColumnSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                StrokeThickness="0"
                Padding="20,15"
                BackgroundColor="#2E7D32">
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="12" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Image Source="white_back.png" 
                       HeightRequest="22" 
                       WidthRequest="22"
                       VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackButtonClicked"/>
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="Change PIN" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" BackgroundColor="#F8F9FA">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- CURRENT PIN SECTION -->
                <Frame BackgroundColor="White" 
                       CornerRadius="12" 
                       Padding="20" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="CURRENT PIN" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="#000000"/>
                        <Label Text="Enter your current 6-digit PIN for verification." 
                               FontSize="12" 
                               TextColor="#666666"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,5,0,10"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Current PIN*" FontSize="12" TextColor="#666666"/>
                            <Border Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#F8F9FA"
                                    Padding="10,0"
                                    HeightRequest="50">
                                <Entry x:Name="CurrentPinEntry"
                                       Placeholder="Enter current PIN"
                                       IsPassword="True"
                                       MaxLength="6"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       TextColor="#000000"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- NEW PIN SECTION -->
                <Frame BackgroundColor="White" 
                       CornerRadius="12" 
                       Padding="20" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="NEW PIN" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="#000000"/>
                        <Label Text="Create a new 6-digit PIN for your account." 
                               FontSize="12" 
                               TextColor="#666666"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,5,0,10"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="New PIN*" FontSize="12" TextColor="#666666"/>
                            <Border Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#F8F9FA"
                                    Padding="10,0"
                                    HeightRequest="50">
                                <Entry x:Name="NewPinEntry"
                                       Placeholder="Enter new PIN (6 digits)"
                                       IsPassword="True"
                                       MaxLength="6"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       TextColor="#000000"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                            <Label Text="Confirm New PIN*" FontSize="12" TextColor="#666666"/>
                            <Border Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#F8F9FA"
                                    Padding="10,0"
                                    HeightRequest="50">
                                <Entry x:Name="ConfirmPinEntry"
                                       Placeholder="Confirm new PIN"
                                       IsPassword="True"
                                       MaxLength="6"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       TextColor="#000000"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- PIN REQUIREMENTS -->
                <Frame BackgroundColor="White" 
                       CornerRadius="12" 
                       Padding="20" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="PIN REQUIREMENTS" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="#000000"/>
                        <Label Text="Make sure your new PIN follows these rules:" 
                               FontSize="12" 
                               TextColor="#666666"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,5,0,10"/>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="• Must be exactly 6 digits"
                                   FontSize="13"
                                   TextColor="#6C757D"/>
                            <Label Text="• Cannot be sequential (e.g., 123456)"
                                   FontSize="13"
                                   TextColor="#6C757D"/>
                            <Label Text="• Cannot be repeating (e.g., 111111)"
                                   FontSize="13"
                                   TextColor="#6C757D"/>
                            <Label Text="• Use different numbers for security"
                                   FontSize="13"
                                   TextColor="#6C757D"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="UpdatePinButton"
                        Text="UPDATE PIN"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="12"
                        Margin="0,10,0,30"
                        Clicked="OnUpdatePinClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="ProcessingOverlay" 
              IsVisible="False"
              HorizontalOptions="Fill"
              VerticalOptions="Fill"
              BackgroundColor="Transparent">
            <VerticalStackLayout Spacing="15" 
                                HorizontalOptions="Center" 
                                VerticalOptions="Center">
                <ActivityIndicator x:Name="ProcessingIndicator"
                                   Color="#2E7D32"
                                   IsRunning="False"
                                   HeightRequest="40"
                                   WidthRequest="40"/>
                <Label x:Name="ProcessingLabel"
                       Text="Updating PIN..."
                       FontSize="14"
                       TextColor="#2E7D32"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>